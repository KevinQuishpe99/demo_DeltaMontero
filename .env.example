# Copia a .env.local y completa (no subas claves a git).

# --- PostgreSQL (Azure — Montero_db, producción) ---
DB_HOST=data-base-src.postgres.database.azure.com
DB_PORT=5432
DB_NAME=Montero_db
DB_USER=
DB_PASSWORD=
DB_SSL=true
DB_POOL_MAX=2
DB_CONNECTION_TIMEOUT_MS=30000
# PG_DATABASE_URL=postgresql://usuario:clave@host:5432/Montero_db?sslmode=require
# Prueba: npm run test:pg-connection

# --- SQL Server origen (solo migración local → Postgres) ---
# DB_USER=sa
# DB_PASSWORD=
# DB_SERVER=localhost
# DB_NAME=bandavanoni_new_2018_resp
# DB_PORT=1433
# DB_REQUEST_TIMEOUT_MS=120000

# --- Opción A: OpenAI (si el proyecto tiene modelos habilitados) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Con API oficial (sin OPENAI_BASE_URL) el agente BI usa Responses API. Forzar Chat Completions: OPENAI_USE_RESPONSES_API=0
# OPENAI_USE_RESPONSES_API=1
# OPENAI_MODEL_FALLBACKS=gpt-3.5-turbo,gpt-3.5-turbo-0125

# --- Opción B: Azure OpenAI (prioridad sobre A si las tres variables existen) ---
# AZURE_OPENAI_ENDPOINT=https://TU_RECURSO.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=nombre-del-deployment-en-Azure
# AZURE_OPENAI_API_VERSION=2024-10-21

# --- Opción C: API compatible (OpenRouter, Groq, LM Studio, etc.) ---
# OPENAI_API_KEY=clave_del_proveedor
# OPENAI_BASE_URL=https://openrouter.ai/api
# OPENAI_MODEL=openai/gpt-4o-mini

SYNC_ID_EMPRESAS=1
# YYYYMM del SP; opcional, si no va, el código usa el mes calendario actual.
# SYNC_PERIODOS=202604

# ETL programado (Vercel Cron → GET /api/etl) y disparo manual (POST)
# En Vercel: crea CRON_SECRET; el cron envía Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=
# POST manual: curl -H "Authorization: Bearer TU_SECRETO" -X POST https://tu-app/api/etl
# ETL_SECRET=

# Límites de contexto (modelos ~16k tokens): no subir sin necesidad.
# SQL_AI_MAX_ROWS=60
# SQL_QUERY_MAX_ROWS=2000
# Filas máximas en CSV por POST /api/export-csv (default 50000, techo 200000).
# SQL_EXPORT_MAX_ROWS=50000
# Filas por consulta al exportar en lotes (default 3000, rango 200–10000).
# SQL_EXPORT_CHUNK_SIZE=3000
# TOOL_OUTPUT_MAX_CHARS=45000
# CHAT_HISTORY_MAX_MESSAGES=14
# CHAT_MESSAGE_MAX_CHARS=10000
# Máximo de tool_calls por mensaje (default 1 = un solo SQL; subir solo si mezclas skills distintas).
# BI_MAX_TOOL_CALLS_PER_TURN=1
# Rondas de consulta SQL antes de forzar síntesis (default 1). No incluye la vuelta final solo-texto.
# BI_MAX_ITERATIONS=1
# Trazas en consola del servidor (skills, SQL resumido, iteraciones). Desactivar: BI_DEBUG_LOGS=0
# BI_DEBUG_LOGS=0

# Consultas SQL: solo consola del servidor ([BI SQL] en terminal). Desactivar: BI_LOG_SQL_CONSOLE=0
# BI_LOG_SQL_CONSOLE=0
# Mostrar consultas SQL en el chat (texto en stream). true = visible, false = oculto (default).
# BI_SHOW_SQL_IN_CHAT=true
# Máximo de tokens de salida por vuelta (default 2048 en chat = más rápido).
# BI_MAX_COMPLETION_TOKENS=2048
# Prompt corto (default activo). Desactivar ejemplos largos: BI_FAST_PROMPT=1
# BI_FAST_PROMPT=1
# Temperatura y top_p del agente BI (defaults: 1 y 1). OpenAI admite temperature hasta 2 en algunos modelos.
# BI_LLM_TEMPERATURE=1
# BI_LLM_TOP_P=1

# Login demo (credenciales fijas; mismo UI que CORA)
# AUTH_USER=cora
# AUTH_PASSWORD=CoraDemo2024!
# AUTH_SESSION_SECRET=genera-un-secreto-largo-aleatorio

# --- Velocidad percibida / menos carga ---
# Cache en memoria del resultado SQL por texto de consulta (ms). Default 20000. 0 = desactivar. Máx. 120000.
# SQL_RESULT_CACHE_TTL_MS=45000
# TTL del bloque METADATA por cookie de sesión (ms). Default 300000 (5 min). Máx. 1800000 (30 min).
# METADATA_SESSION_TTL_MS=600000

# SQL Server origen (solo scripts de migración npm run migrate:pg-*)
# MSSQL_SERVER=localhost
# MSSQL_PORT=1433
# MSSQL_USER=sa
# MSSQL_PASSWORD=
# MSSQL_DATABASE=bandavanoni_new_2018_resp

# ODOO_BASE_URL=https://tu-instancia.odoo.com
# ODOO_DB=nombre_bd_odoo
# ODOO_LOGIN=correo_usuario
# ODOO_PASSWORD=contraseña_o_api_key
# Opcional: si usas API key con uid fijo, define ODOO_UID y omite ODOO_LOGIN.
# ODOO_UID=75
# ODOO_PARTNER_PAGE_SIZE=5000
